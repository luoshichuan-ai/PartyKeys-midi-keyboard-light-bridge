{
  "name": "partykeys-midi-light",
  "version": "1.0.0",
  "description": "PartyKeys MIDI Light Controller — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "install-host": "node install-host.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "rebuild": "electron-rebuild -f -w midi"
  },
  "dependencies": {
    "@julusian/midi": "^3.6.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "@electron/rebuild": "^3.6.0"
  },
  "build": {
    "appId": "com.partykeys.midilight",
    "productName": "PartyKeys MIDI Light",
    "files": [
      "main.js",
      "preload.js",
      "host.js",
      "install-host.js",
      "midi/**",
      "renderer/**",
      "node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "renderer/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "renderer/icon.icns",
      "category": "public.app-category.music"
    },
    "nsis": {
      "installerIcon": "renderer/icon.ico",
      "runAfterFinish": true
    },
    "afterInstall": "install-host.js"
  }
}
